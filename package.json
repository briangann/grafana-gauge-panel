{
  "name": "briangann-gauge-panel",
  "private": true,
  "version": "2.0.2",
  "description": "Grafana D3 Gauge Panel",
  "main": "module.js",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix && prettier --write --list-different .",
    "e2e": "pnpm exec cypress install && pnpm exec grafana-e2e run",
    "e2e:update": "pnpm exec cypress install && pnpm exec grafana-e2e run --update-screenshots",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briangann/grafana-gauge-panel.git"
  },
  "author": "Brian Gann",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/briangann/grafana-gauge-panel/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@grafana/eslint-config": "^8.2.0",
    "@grafana/tsconfig": "^2.0.0",
    "@stylistic/eslint-plugin-ts": "^2.9.0",
    "@swc/core": "^1.3.90",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/d3": "7.4.3",
    "@types/d3-scale": "4.0.9",
    "@types/glob": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.14.194",
    "@types/node": "^20.8.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "cspell": "7.3.8",
    "css-loader": "^6.7.3",
    "d3": "7.9.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-jsdoc": "^51.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^10.2.7",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "prettier": "^2.8.7",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.3",
    "terser-webpack-plugin": "^5.3.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.1",
    "@grafana/i18n": "12.4.1",
    "@grafana/runtime": "12.4.1",
    "@grafana/schema": "12.4.1",
    "@grafana/ui": "12.4.1",
    "@types/uuid": "8.3.4",
    "d3-ease": "3.0.1",
    "d3-scale": "4.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "semver": "^7.5.4",
    "tslib": "2.8.1",
    "uuid": "^9.0.1"
  },
  "homepage": "https://github.com/briangann/grafana-gauge-panel",
  "engines": {
    "node": ">= 24"
  },
  "packageManager": "pnpm@8.9.2"
}
