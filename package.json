{
  "name": "briangann-gauge-panel",
  "private": true,
  "version": "2.1.0",
  "description": "Grafana D3 Gauge Panel",
  "main": "module.js",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix && prettier --write --list-different .",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briangann/grafana-gauge-panel.git"
  },
  "author": "Brian Gann",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/briangann/grafana-gauge-panel/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.5.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.30",
    "@swc/helpers": "^0.5.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "15.0.7",
    "@types/d3": "7.4.3",
    "@types/d3-scale": "4.0.9",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "10.0.0",
    "css-loader": "^6.11.0",
    "d3": "7.9.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "~7.0.1",
    "eslint-webpack-plugin": "^5.0.3",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^13.0.6",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "playwright": "^1.59.1",
    "prettier": "^2.8.8",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.99.0",
    "sass-loader": "13.3.3",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "12.4.2",
    "@grafana/i18n": "12.4.2",
    "@grafana/runtime": "12.4.2",
    "@grafana/schema": "12.4.2",
    "@grafana/ui": "12.4.2",
    "d3-ease": "3.0.1",
    "d3-scale": "4.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.7.4",
    "tslib": "2.8.1",
    "uuid": "^13.0.0"
  },
  "homepage": "https://github.com/briangann/grafana-gauge-panel",
  "engines": {
    "node": ">= 24"
  },
  "packageManager": "pnpm@8.9.2"
}
